{
  "name": "connexify-leadflow",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev:client": "npm run dev -w client",
    "dev:server": "npm run dev -w server",
    "build": "npm run build -w client",
    "start:server": "npm run start -w server",
    "db:migrate": "npm run db:migrate -w server",
    "db:purge-draft-sales": "npm run db:purge-draft-sales -w server",
    "redis:up": "docker compose up -d redis",
    "redis:down": "docker compose down",
    "redis:logs": "docker compose logs -f redis",
    "redis:ping": "node -e \"const Redis=require('ioredis'); const r=new Redis(process.env.REDIS_URL||'redis://127.0.0.1:6379'); r.ping().then(p=>{console.log(p);process.exit(0)}).catch(e=>{console.error(e.message);process.exit(1)})\""
  }
}
