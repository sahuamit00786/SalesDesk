# Aurinko — "Continue with Google" (Gmail + Google Calendar)
# Copy these into your real .env. The integration stays dormant (legacy
# direct-Google flow keeps working) until CLIENT_ID/SECRET are set.

# From app.aurinko.io → your application → Settings
AURINKO_CLIENT_ID=
AURINKO_CLIENT_SECRET=

# From app.aurinko.io → Settings → Signing secret (webhook HMAC verification)
AURINKO_SIGNING_SECRET=

# Public base URL of THIS server (no trailing slash). Used to build:
#   OAuth callback:  {PUBLIC_SERVER_URL}/api/v1/aurinko/callback
#   Webhook URL:     {PUBLIC_SERVER_URL}/api/v1/webhooks/aurinko
# Must be reachable from the internet (Aurinko validates it synchronously).
PUBLIC_SERVER_URL=https://api-leadfin.upgrowventures.com

# Optional overrides
# AURINKO_API_BASE=https://api.aurinko.io
# AURINKO_SUBSCRIPTION_HEAL_INTERVAL_MS=86400000
