# Copy to `.env` at the repository root (same folder as this file), or use `server/.env`.
# The API loads `server/.env` first, then this file with override — root `.env` wins on duplicate keys.

# --- Client (Vite) ---
# Proxy target when running `npm run dev` in client (must match server PORT). Default: http://127.0.0.1:4000
# VITE_DEV_API_PROXY=http://127.0.0.1:4000
# Optional: override API origin; dev normally uses Vite proxy to /api -> server
# VITE_API_BASE_URL=http://localhost:4000/api/v1

# --- Server ---
NODE_ENV=development
PORT=4000
CLIENT_ORIGIN=http://localhost:5173

# Base URL for links saved on meetings (PDFs, recordings). Defaults to http://localhost:<PORT>
# PUBLIC_API_URL=http://localhost:4000

# MySQL 8
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=leadflow
DB_USER=leadflow
DB_PASSWORD=leadflow

# JWT (use long random strings in real environments)
JWT_ACCESS_SECRET=change-me-access-secret-min-16
JWT_REFRESH_SECRET=change-me-refresh-secret-min-16
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Redis (optional — rate limit + dashboard cache skip if unset)
# REDIS_URL=redis://127.0.0.1:6379

# --- Google Calendar / Meet (all four required for Meet links on new meetings) ---
# Use scripts/getGoogleRefreshToken.js from repo root with scope https://www.googleapis.com/auth/calendar
# GOOGLE_REDIRECT_URI must match the OAuth client’s authorized redirect URI (and the value used when obtaining the refresh token).
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=http://localhost:4000/api/v1/google/callback
# GOOGLE_REFRESH_TOKEN=

# --- Gmail push (Pub/Sub) — near-real-time inbox sync after company Gmail OAuth ---
# 1) Create a Pub/Sub topic in the same GCP project as your Gmail API OAuth client (or grant cross-project).
# 2) Grant publish: gmail-api-push@system.gserviceaccount.com on the topic (Gmail → Pub/Sub).
# 3) Create a push subscription to POST https://<PUBLIC_API>/api/v1/webhooks/gmail-pubsub with OIDC audience = that URL.
# 4) Set GMAIL_PUBSUB_TOPIC to the full resource name, e.g. projects/my-proj/topics/gmail-inbox
# GMAIL_PUBSUB_TOPIC=
# Exact push URL (must match Pub/Sub subscription "Audience" for OIDC). Required unless GMAIL_PUBSUB_VERIFY_JWT=false
# GMAIL_PUBSUB_PUSH_AUDIENCE=https://api.example.com/api/v1/webhooks/gmail-pubsub
# GMAIL_PUBSUB_VERIFY_JWT=true — set to false only for local debugging without OIDC
# GMAIL_WATCH_RENEW_INTERVAL_MS=43200000 — renew Gmail watch before 7d expiry (default 12h)

# --- Meeting cron: reminders, live/completed status, optional Meet bot + transcription + AI summary ---
# MEETING_CRON_ENABLED=false — set to false to disable the whole minute cron (default: enabled if unset)
# ENABLE_MEETING_BOT=true — master switch: allow the server to run the bot when organizers approve (recording_bot_consent).
# Per-meeting consent is stored in the DB when the organizer checks "Enable AI recording bot" or accepts the banner — .env is not toggled per meeting.
#
# Cross-platform audio (ffmpeg must be on PATH, or set MEETING_BOT_FFMPEG_EXE below). Pick ONE approach per OS:
#
# Windows (preferred): install ffmpeg; enable "Stereo Mix" in Sound → Recording (show disabled devices), OR install VB-Audio Virtual Cable.
#   If the API server is started from an IDE and you see "spawn ffmpeg ENOENT", set an absolute path (no quotes needed):
#   MEETING_BOT_FFMPEG_EXE=C:\Users\YOU\AppData\Local\Microsoft\WinGet\Packages\Gyan.FFmpeg_...\ffmpeg-8.1.1-full_build\bin\ffmpeg.exe
#   List DirectShow devices (exact order matters — do not put "dummy" before -f dshow):
#   ffmpeg -hide_banner -f dshow -list_devices true -i dummy
#   FFmpeg may print "Error opening input file dummy" after the device list; that line is harmless once you see audio= names.
#   Then set the full dshow input, e.g. (no outer quotes in .env; use the exact name from the list):
#   MEETING_BOT_WIN_DSHOW=audio=Stereo Mix (Realtek(R) Audio)
#   Microphone / webcam devices capture the mic or room, not Meet tab audio — use Stereo Mix or VB-Cable output for system/meet sound.
# macOS: install BlackHole (or similar), route Meet output to it; then e.g.:
#   MEETING_BOT_MAC_AVFOUNDATION=:BlackHole 2ch
# Linux (server/headless): Xvfb + Pulse null sink is used when DISPLAY is unset; ensure pulseaudio, Xvfb installed.
#
# MEETING_BOT_HEADLESS=true — use headless Chromium (Meet may block; try false if join fails)
# MEETING_BOT_BROWSER_EXECUTABLE=C:\Users\YOU\AppData\Local\Chromium\Application\chrome.exe — system Chromium/Chrome path (optional; wins over channel)
# MEETING_BOT_CHROME_CHANNEL=chrome — use installed Google Chrome / Edge channel instead of bundled Chromium (optional; ignored if MEETING_BOT_BROWSER_EXECUTABLE is set)
# MEETING_BOT_SKIP_RECORDING=true — join only, no ffmpeg (transcription will fail unless you add another source)
# MEETING_BOT_FFMPEG_DEBUG=true — log ffmpeg stderr
#
# GROQ_API_KEY= — Groq API key (OpenAI-compatible base URL; meeting transcription + summary)
# GROQ_MODEL=llama-3.3-70b-versatile — chat completions for meeting summaries (replaces decommissioned llama3-70b-8192; see https://console.groq.com/docs/deprecations )
# GROQ_TRANSCRIBE_MODEL=whisper-large-v3-turbo — audio transcription (replaces deprecated distil-whisper-large-v3-en / older whisper ids; see Groq supported models)

# --- SMTP (Gmail / Google Workspace: use an App Password) ---
# Required in production for signup verification emails. In development, OTP is printed to the server console if SMTP is omitted.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
# SMTP_SECURE=false
SMTP_USER=your-account@gmail.com
SMTP_PASS=your-app-password
# SMTP_FROM="SalesDesk <your-account@gmail.com>"
# Display name in transactional emails (OTP, invites, web form wraps). Default: SalesDesk
# APP_PUBLIC_NAME=SalesDesk
